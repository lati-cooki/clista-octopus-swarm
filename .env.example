# ==============================================================
# ClisTa Octopus Swarm: Environment Configuration
# ==============================================================

# --- LIVE LLM INTEGRATION KEYS ---
# Required if you want the Mantle Orchestrator to route tasks to live AI models.
# If omitted, the swarm gracefully falls back to deterministic simulation logic.
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="AIza..."

# --- ENTERPRISE CI/CD GOVERNANCE ---
# The target webhook to trigger upon 1.0 Coherence (Consensus or Arbitrator overrides).
# Example: GitHub Actions Dispatch URL, Jira Webhook, Slack channel, etc.
ENTERPRISE_WEBHOOK_URL="https://api.github.com/repos/your-org/your-repo/dispatches"

# --- FIRESTORE CONFIGURATION ---
# Assumes Application Default Credentials (ADC) are set locally or on Cloud Run.
# Ensure your GCP Project ID has Datastore/Firestore enabled.
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
